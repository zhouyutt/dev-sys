# Docker Compose 部署变量示例

# 应用配置
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d
FRONTEND_URL=http://your-domain-or-server-ip:8082
MAX_FILE_SIZE=10485760

# 数据库配置
DB_NAME=dive_erp
DB_USER=dive_user
DB_PASSWORD=replace-with-a-strong-db-password
MYSQL_ROOT_PASSWORD=replace-with-another-strong-root-password

# 端口与绑定地址
BACKEND_BIND_ADDRESS=0.0.0.0
BACKEND_HOST_PORT=3000
FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_HOST_PORT=8082
MYSQL_BIND_ADDRESS=127.0.0.1
MYSQL_HOST_PORT=3307

# 可选：如果服务器访问 npm 官方源慢，再按需开启
# NPM_REGISTRY=https://registry.npmmirror.com
# PNPM_VERSION=9.15.9
