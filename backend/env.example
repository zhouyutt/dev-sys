# 服务器配置
PORT=3000
NODE_ENV=production

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_NAME=dive_erp
DB_USER=dive_user
DB_PASSWORD=replace_with_a_strong_db_password

# JWT配置
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 前端URL
FRONTEND_URL=http://localhost:8082
